# PropulsionLab — environment configuration
# Copy to .env and adjust for your deployment.

# CORS: comma-separated list of allowed origins (backend).
# For local dev the default (localhost:5173) is used when this is unset.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Backend host/port (used by docker-compose / uvicorn)
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
